parameters:
    level: 5
    treatPhpDocTypesAsCertain: false
    paths:
        - src
        - Resources
        - inc
        - dropin
        - tests
    bootstrapFiles:
        - vendor/autoload.php
        - tests/phpunit/bootstrap.php
    scanFiles:
        - stubs/wp-cli.stub.php
    stubFiles:
        - stubs/wp-cli.stub.php
